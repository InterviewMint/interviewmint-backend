# Environment Variables
PORT="8000"
DATABASE_URL="postgresql://neondb_owner:xxxxxxxxxxxx@xxxxxxxxxxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
NODE_ENV="development"
FRONTEND_URL="http://localhost:8080"

# JWT Secrets
REFRESH_TOKEN_SECRET="your_refresh_token_secret_here"
ACCESS_TOKEN_SECRET="your_access_token_secret_here"

# SendGrid
SENDGRID_API_KEY="your_sendgrid_api_key_here"
SENDGRID_FROM_EMAIL="your_sendgrid_from_email_here"
EMAIL_VERIFY_EXPIRY_MINUTES="30"

# OAuth Configuration
OAUTH_CLIENT_ID="your_oauth_client_id_here"
OAUTH_CLIENT_SECRET="your_oauth_client_secret_here"
OAUTH_REDIRECT_URI="your_oauth_redirect_uri_here"