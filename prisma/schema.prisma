// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema


generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// User Model - Centralized Identity & Role Management for Student, Company HR, Recruiter, TPO, College Admin, Platform Admin
model User {
  id String @id @default(uuid())

  // Core Identity
  fullName  String
  email     String  @unique
  phone     String? @unique
  resumeUrl String?

  // Social Links
  linkedInUrl  String?
  githubUrl    String?
  portfolioUrl String?
  twitterUrl   String?

  // Authentication
  passwordHash                    String?
  authProvider                    AuthProvider @default(EMAIL)
  providerId                      String?
  emailVerified                   Boolean      @default(false)
  phoneVerified                   Boolean      @default(false)
  lastLoginAt                     DateTime?
  emailVerificationToken          String?      @unique
  emailVerificationTokenExpiresAt DateTime?
  tokenVersion                    Int          @default(0)

  // Role & Type (Single-table polymorphic)
  userType UserType @default(CANDIDATE)
  // CANDIDATE | COMPANY_ADMIN | RECRUITER | COLLEGE_ADMIN | TPO | SUPER_ADMIN

  // Optional structured profile (future safe)
  profile Json? // resume, company details, metadata, etc.

  // Status & Lifecycle
  isActive       Boolean @default(true)
  onboardingStep Int     @default(0)

  // App Settings / Flags
  languagePreference String? // "en", "hi", etc.
  notificationPrefs  Json? // email/sms/push toggles
  featureFlags       Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emailVerified, createdAt])
}

enum UserType {
  CANDIDATE
  RECRUITER
  COMPANY_ADMIN
  COLLEGE_ADMIN
  TPO
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
  MICROSOFT
  SSO
}

